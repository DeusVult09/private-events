
<div class="display-card">
    <h2><%= @event.name %></h2>

    <h3>Description:</h3>
    <p><%= @event.description %></p>

    <h3>Date:</h3>
    <p><%= @event.date %></p>

    <h3>Location:</h3>
    <p><%= @event.location %></p>

    <h3>Created by:</h3>
    <p><%= @event.creator.name %></p><br>
    
    <%= link_to "Back to Events", events_path %><br>

    <% if @event.creator != current_user %>
       <%= button_to "Attend Event", event_attendances_path(@event), method: :post %>
    <% end %><br>

    <% if @event.creator == current_user %>
      <%= link_to "Edit", edit_event_path(@event) %>
      <%= button_to "Delete Event",
      @event, 
      method: :delete, 
      form: { data: { turbo_confirm: "Are you sure?" } } %>
    <% end %>
</div>

