
<div class="display-card">
    <h2><%= @event.name %></h2>

    <h3>Description:</h3>
    <p><%= @event.description %></p>

    <h3>Date:</h3>
    <p><%= @event.date %></p>

    <h3>Location:</h3>
    <p><%= @event.location %></p>

    <h3>Created by:</h3>
    <p><%= @event.creator.name %></p><br>
    
    <%= link_to "Back to Events", events_path %><br><br>
    
    <% if @event.creator != current_user %>
      <% attendance = current_user.attendances.find_by(event: @event) %>

      <% if attendance.nil? %>
        <%= button_to "Attend this Event", event_path(@event), method: :post %>
      <% else %>
        <p>You are already attending this event (<%= attendance.status %>)</p>
      <% end %>
    <% else %>
      <p>You created this event</p>
    <% end %>

    <% if @event.creator == current_user %>
      <%= link_to "Edit", edit_event_path(@event) %><br><br>
      <%= button_to "Delete Event",
      @event, 
      method: :delete, 
      form: { data: { turbo_confirm: "Are you sure?" } } %>
    <% end %><br><br>

    <%= link_to "Add New Event", new_event_path %>
</div>

